skill:addEffect("cardskill", {
  can_use = Util.FalseFunc,
  on_effect = function(self, room, effect)  --effect CardEffectData
    if effect.responseToEvent then
      effect.responseToEvent.isCancellOut = true
      effect.responseToEvent.extra_data = effect.responseToEvent.extra_data or {}
      effect.responseToEvent.extra_data.tsiac_keejs_dzius_keejs = effect.from
    end
  end,
})

local spec = {
  global = true,
  priority = 0,  --旣爲0 return true
  can_trigger =  Util.TrueFunc, --trigger逐个詢問 改爲ask--抵消爲何寫于流程 不可能不生成旹機--中斷旹機 技能用不了--瀕死正用旹機 --p return true data.asked   priority = 0,
  on_trigger = function (self, event, target, player, data)
    if
      data.card.type ~= Card.TypeTrick or (data.disresponsive or data.unoffsetable) then
        return true 
    end

    local pattern=""  --可用牌于此詢問歬加入 data --被禁不加
    local names={}
    if #data.tos<2 then --比如
      pattern= "buac_hzfan_mujs_nzjen,tsiac_keejs_dzius_keejs"
      names={"buac_hzfan_mujs_nzjen","tsiac_keejs_dzius_keejs"}
    else
      pattern = "buac_hzfan_mujs_nzjen"
      names={"buac_hzfan_mujs_nzjen"}
    end

    local canuse={}
    for _, name in ipairs(names) do
      if not (table.contains(data.prohibitedCardNames or Util.DummyTable, name))  then
        table.insert(canuse,name)
      end
    end

    local room = player.room
    local players = {}
    Fk.currentResponsePattern =pattern  --有ask 此有何用

      --全不能用才不加--止需有1則問--技能可以多匹配--葢牌有才算 不能分是否爲nulli
    for _, p in ipairs(room.alive_players) do
      local playercanuse={}

      for _, name in ipairs(canuse) do
        local cardCloned = Fk:cloneCard(name)
        if not p:prohibitUse(cardCloned) then  --都被禁不察 
          table.insert(playercanuse, name)
        end
      end
      if #playercanuse>0 then  --要不continue 

        local cards = p:getHandlyIds()  --改handly?
        for _, c in ipairs (player:getCardIds("j")) do
          local card = player:getVirualEquip(id)
          if card and card.name == "koarbiuk_card" then  --需要?直接加j--function getkoar
            table.insert(cards,c) --id
          end
        end

        for _, cid in ipairs(cards) do
          for  _, name in ipairs(playercanuse) do

            if Fk:getCardById(cid).trueName == name and
              (not (
                data:isDisresponsive(p) or
                data:isUnoffsetable(p)
              ))
            then
              table.insert(players, p)
              break
            end
          end
        end

        if not table.contains(players, p) then
          for  _, name in ipairs(playercanuse) do

          -- Self = p -- for enabledAtResponse
            for _, s in ipairs(table.connect(p.player_skills, rawget(p, "_fake_skills"))) do
              ---@cast s ViewAsSkill
              if
                s.pattern and
                Exppattern:Parse(name):matchExp(s.pattern) and  --此name in playercanuse  --str
                (s:enabledAtNullification(p, data) or s:enabledAtResponse(p)) and
                (not (
                  data:isDisresponsive(p) or
                  data:isUnoffsetable(p)
                ))
              then
                table.insert(players, p)
                break
              end
            end
          end
        end

      end  --上continue 
    end  --break

    local prompt = ""
    if data.to then
      prompt = "#AskForNullification::" .. data.to.id .. ":" .. data.card.name
    elseif data.from then
      prompt = "#AskForNullificationWithoutTo:" .. data.from.id .. "::" .. data.card.name
    end

    local extra_data
    if #data.tos > 1 then
      local parentUseEvent = room.logic:getCurrentEvent():findParent(GameEvent.UseCard)
      if parentUseEvent then
        extra_data = { useEventId = parentUseEvent.id, effectTo = data.to.id }
      end
    end

    if #players > 0 
    --and data.card.trueName == "buac_hzfan_mujs_nzjen" 
    then  --錦囊皆可?
      room:animDelay(2)  --若个速過條
    end

    local params = { ---@type AskToUseCardParams  --不含expand_pile 
      skill_name = "buac_hzfan_mujs_nzjen",
      pattern = pattern,
      prompt = prompt,
      cancelable = true,
      extra_data = extra_data,
      event_data = data
    }
    local use = room:askToNullification(players, params)  --直接問全部?on_trigger  --額外? --緟寫 req 
    if use then
      use.toCard = data.card
      use.responseToEvent = data
      room:useCard(use)
    end

    Fk.currentResponsePattern = nil  --有何用 旹機止askToNullification
    return true
  end,
}

