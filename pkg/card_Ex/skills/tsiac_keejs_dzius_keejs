local skill = fk.CreateSkill {
  name = "tsiac_keejs_dzius_keejs_skill",
}

Fk:loadTranslationTable{
  ["tsiac_keejs_dzius_keejs_skill"] = "將計就計",
  ["#tsiac_keejs_dzius_keejs-use"] = "%src 使用%arg，是否使用【將計就計】抵消 獲得%arg？",
