cardSkill:addEffect(fk.EnterDying, {
  priority = 0,
  global = true,
  can_trigger = function(self, event, target, player, data)
    if player~=target then return end
    local room = player.room
    local players=S.getHolders({"tsja_szji_hzfan_hzoon"})
      if  #players > 0  and #room.players>#room.alive_players  then
        event:setCostData(self,{players=players})
        return  true
      end

    
  end,
  on_trigger = function(self, event, target, player, data)
    local room = player.room

    local params={  --旣視感--askToUseRealCard active  非askForUse 无旹機 can_use有效
      pattern = "tsja_szji_hzfan_hzoon",
      skill_name = "tsja_szji_hzfan_hzoon",  --提示
      prompt = "#tsja_szji_hzfan_hzoon-use:"..target.id,
      cancelable = true,
      -- skip = true,
      -- event_data = data,
      extra_data = {
        tsja_szji_hzfan_hzoon = true,
      }
    }
    
    local use = room:askToNullification(event:getCostData(self).players, params)  --選上家再選下家?
    if use then 

      use.toCard=use.card
      use.responseToEvent=data
      room:useCard(use)
    end

  end,
})

return cardSkill
