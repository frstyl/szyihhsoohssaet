local phuohgxim = fk.CreateSkill {
  name = "phuohgxim",
}

Fk:loadTranslationTable{
["phuohgxim"] = "抚琴",
[":phuohgxim"] = "預段始旹或當伱受到傷害後選擇1角色与1項對其發動,➀伱令其抽x➁伱弃其x(x爲伱已損體力值+1)",

["#phuohgxim"]="抚琴 選擇一角色 抽弃 %arg",
["phuohgxim-discard"] = "抚琴 選擇弃牌",

}


phuohgxim_spec={
  on_cost = function (self, event, target, player, data)
    local room = player.room
    local success, dat = room:askToUseActiveSkill(player, {
      skill_name = "phuohgxim_active",
      prompt = "#phuohgxim:::"..(player:usedSkillTimes(phuohgxim.name, Player.HistoryRound) + 1),
      cancelable = true,
      skip = true,
    })
    if success and dat then
      event:setCostData(self, {tos = dat.targets, choice = dat.interaction})
      return true
    end
  end,
  on_use = function (self, event, target, player, data)
    local tos = event:getCostData(self).tos
    local skill = Fk.skills["phuohgxim_active"]
    skill.interaction = skill.interaction or {}
    skill.interaction.data = event:getCostData(self).choice
    skill:onUse(player.room, {
      from = player,
      tos = tos,
    })
  end,
}


phuohgxim:addEffect(fk.EventPhaseStart, {
  anim_type = "drawcard",
  can_trigger = function(self, event, target, player, data)
    return target == player and player:hasSkill(phuohgxim.name) and player.phase == Player.Start
  end,
  on_cost = phuohgxim_spec.on_cost,
  on_use = phuohgxim_spec.on_use,
})

phuohgxim:addEffect(fk.Damaged, {
  anim_type = "masochism",
  can_trigger = function (self, event, target, player, data)
    return target == player and player:hasSkill(phuohgxim.name)
  end,
  on_cost = phuohgxim_spec.on_cost,
  on_use = phuohgxim_spec.on_use,
})



return phuohgxim
