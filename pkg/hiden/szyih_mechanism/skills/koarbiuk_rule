koarbiuk_rule:addEffect(fk.EventPhaseStart, {  --手牌可用之牌 葢牌何用
  priority = 0,
  can_trigger = function(self, event, target, player, data)
    if not ( target==player --同旹 止問1次
    and target.phase == Player.Judge) then return nil 
    end   --應爲單獨旹機
    return true
  end,

  on_trigger = function(self, event, target, player, data)
    local room=player.room
    local cardNames={"ssaet","hzaac_tshjes","thou_liac_hzvoans_dduoh"}      --令牌技能註冊何旹可用??  --暗殺--"^(.)|.|.|.|ambush__ssaet",
    local pattern=""
    local setPattern =function()
          local t={}
          local n={}
        for _, name in ipairs(cardNames)do

          if name=="ssaet" then
            table.insert(t,tostring(Exppattern{ name = {"ambush__ssaet"} }))  --id? name?
          else
            table.insert(t,name)
          end
        end
        pattern=table.concat(t,";")
    end
    while 1 do
      local players={}
      local expand={}
      for _, p in ipairs(room.alive_players) do
        if #S.getPlayerKoarbiukCards(p)>0 and p~=target then 
          table.insert(players, p)
          expand[p.id]=S.getPlayerKoarbiukCards({p},"hzaac_tshjes,thou_liac_hzvoans_dduoh;.|.|.|.|ambush__ssaet")
          -- return true 
        end
      end
      if #players==0 then return end
      setPattern()
      local ids=S.getAllKoarbiukCards(table.concat(cardNames,";"))
      -- local ids=S.getAllKoarbiukCards(setPattern())

      local params={
        pattern = tostring(Exppattern{ id = ids }),
        skill_name = "#koarbiuk_rule",  --提示
        prompt = "#koarbiuk-use:"..target.id,
        cancelable = true,
        -- skip = true,
        -- event_data = data,
        extra_data = {
          exclusive_targets = {target.id},  --又用Id矣
          bypass_distances = true,  --葢伏特性
          bypass_times = false,
          extraUse = false,
        }
      }

        Fk.currentResponseReason = "koarbiuk_rule"
        local use = S.askToUseKoarbiukCard(room, players,  params, nil, expand)  --不同角色不同
        if use then
          -- room:addTableMark(use.from, "koarbiuk-phase", use.card.trueName)  --每个牌名1次?

          use.extra_data = use.extra_data or {}
          use.extra_data.koarbiuk = true
          -- use.from:removeVirtualEquip(use.card.id)
          room:useCard(use)
          
          table.removeOne(cardNames,use.card.name)
          if #cardNames==0 then return end
        else
          Fk.currentResponseReason = nil
          return --畢 false 
        end

    end
  end,
})

