      --    table.removeOne(data.to:getTableMark("@@punsmuoh-MarkArmorNullified"), data.id) 
      -- )

      player.room:addPlayerMark(data.to,"@@punsmuoh-MarkArmorNullified",1)  --次數?
      player.room.logic:getCurrentEvent():findParent(GameEvent.UseCard, true):addCleaner(function()
         player.room:removePlayerMark(data.to,"@@punsmuoh-MarkArmorNullified", 1) 
      )
  end,
})
