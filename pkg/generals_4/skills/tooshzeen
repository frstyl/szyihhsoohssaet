local tooshzeen = fk.CreateSkill {
  name = "tooshzeen",
}

Fk:loadTranslationTable{
  ["tooshzeen"] = "妬賢",
  [":tooshzeen"] = "當伱攻程內其它角色不因額定抽牌抽牌旹,伱可与其拼點發動。若伱:贏,伱弃1手牌;沒贏,其須選1項.➀交与伱1♣牌手➁弃♠<font color='red'>♥♦</font>手牌各1➂流失1體力",


  ["#tooshzeen-invoke"] = "妬賢 是否与%src拼點 記得用小點",

  ["#tooshzeen-choose"] = "妬賢 交与 %src ♣牌流失1體力", --♠♥♣♦
  ["#tooshzeen-discard"] = "妬賢 弃1手牌",

  ["$tooshzeen1"] = "何人題下昰詩䛐在此",

  ["$tooshzeen2"] = "或六六之秊或六六之數",
  ["$tooshzeen3"] = "靑竹蛇兒口,黃蜂尾上刺",
  ["$tooshzeen4"] = "事非耦肰也",
  ["$tooshzeen5"] = "取來文策一察便知有无",
}

-- local S = require "packages/szyihhsoohssaet/szyih_guos" 

tooshzeen:addEffect(fk.AfterCardsMove, {
  can_trigger = function(self, event, target, player, data)
    if not player:hasSkill(tooshzeen.name)  then return end
      local tos={}
      for _, move in ipairs(data) do
        if  move.to ~=player and move.toArea == Card.PlayerHand and move.moveReason==fk.ReasonDraw and move.skillName~= "phase_draw" then
            if player:inMyAttackRange(move.to) and player:canPindian(move.to) and not table.contains(tos, move.to) then
              table.insert(tos, move.to)
            end 
          -- for _, info in ipairs(move.moveInfo) do

          --   end
          -- end
        end
      end

    if #tos==0 then return end --同旹抽牌?
    player.room:sortByAction(tos)
    for _, p in ipairs(tos) do
      if not player:hasSkill(tooshzeen.name) then break end
      if not p.dead then
        event:setCostData(self, {tos = {p}})
        self:doCost(event, target, player, data)
      end
    end
  end,
  on_cost = function(self, event, target, player, data)
    local tos=event:getCostData(self).tos
    local room =player.room
    if #tos == 1 then
      if room:askToSkillInvoke(player, {
        skill_name = tooshzeen.name,
        prompt = "#tooshzeen-invoke:"..tos[1].id,
      }) 
      then

        event:setCostData(self, {tos = {}, to=tos[1]})
        return true
      else
        self.cancel_cost = false
        return false
      end

    elseif #tos > 1 then
      local to = room:askToChoosePlayers(player, {
        targets = tos,
        min_num = 1,
        max_num = 1,
        prompt = "#tooshzeen-invoke-multi",
        skill_name = tooshzeen.name,
      })[1]

      if to and #to > 0 then
        tos=table.remove(tos,table.indexOf(to[1]))
        event:setCostData(self, {tos = tos, to=to[1]})
        return true
      else
        self.cancel_cost = false
        return

    end


    end


  end,
  on_use = function(self, event, target, player, data)
    local room = player.room    
    local to=event:getCostData(self).to
    if not player:canPindian(to) then return end
    local pindian = player:pindian({to}, tooshzeen.name)
    if pindian.results[to].winner == player then  
       room:askToDiscard(player, {
          min_num = 1,
          max_num = 1,
          include_equip = false,
          skill_name = tooshzeen.name,
          cancelable = false,
          prompt = "#tooshzeen-discard",
          skip=false,
        })    
        return 
      end--沒贏

    local yes, dat = room:askToUseActiveSkill(to, {
    skill_name = "tooshzeen_active",
    prompt = "#tooshzeen-choose:"..player.id,
    cancelable = true,
    skip = true,  --不執行
  })
    if not yes then
      room:loseHp(to, 1, tooshzeen.name,player)
      return
    end
    if #dat.cards ==1 then
      room:obtainCard(player, dat.cards, true, fk.ReasonGive, to, tooshzeen.name)
    else 
      room:throwCard(dat.cards, tooshzeen.name, to)
    end
  end,
})


return tooshzeen
