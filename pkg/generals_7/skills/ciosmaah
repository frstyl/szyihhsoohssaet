ciosmaah:addEffect("distance", {
  correct_func = function(self, from, to)
    if from:hasSkill(ciosmaah.name) then
      return -1
    end
  end,
})

ciosmaah:addEffect(fk.EventAcquireSkill, {
  can_refresh = function (self, event, target, player, data)
    return target~=player and player:hasSkill(ciosmaah.name,true,true) 
    and player:compareDistance(target, 1, "==")
    and data.skill:getSkeleton()
    and data.skill:getSkeleton().attached_equip
    and
    table.contains({Card.SubtypeDefensiveRide ,Card.SubtypeOffensiveRide, },Fk:cloneCard(data.skill:getSkeleton().attached_equip).sub_type  )

  end,
  on_refresh=function (self, event, target, player, data)
    S.addVirtualEquip(player, data.skill:getSkeleton().attached_equip,ciosmaah.name)
    -- S.handleAddLoseVirtualSkills(player,{data.skill.name},ciosmaah.name)
  end,
})

ciosmaah:addEffect(fk.EventLoseSkill, {
  can_refresh = function (self, event, target, player, data)
    return target~=player and player:hasSkill(ciosmaah.name,true,true) 
    and player:compareDistance(target, 1, "==")
    and data.skill:getSkeleton()
    and data.skill:getSkeleton().attached_equip
    and
    table.contains({Card.SubtypeDefensiveRide ,Card.SubtypeOffensiveRide, },Fk:cloneCard(data.skill:getSkeleton().attached_equip).sub_type  )

  end,
  on_refresh=function (self, event, target, player, data)
    -- S.handleAddLoseVirtualSkills(player,{"-"..data.skill.name},ciosmaah.name )
        S.removeVirtualEquip(player, data.skill:getSkeleton().attached_equip,ciosmaah.name)
  end,
})

return ciosmaah
