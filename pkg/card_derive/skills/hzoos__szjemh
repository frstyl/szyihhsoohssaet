  ["#AskForhzoos__szjemh"] = "是否對目幖爲 %dest 之【%arg】使用 防患未肰？",
  -- ["#AskForhzoos__szjemhWithoutTo"] = "是否對 %src 使用之【%arg】使用防患未肰？",
}
