local tshjitjjevs = fk.CreateSkill{
  name = "tshjitjjevs",
  tags = { Skill.Compulsory },
}

Fk:loadTranslationTable{
  ["tshjitjjevs"] = "七燿",
  [":tshjitjjevs"] = "鎖定恆續.若伱有空武器欄,視爲裝僃七星劍.",

  ["@[:]virtual_equip"] = "虛兵",
  ["$tshjitjjevs1"] = "寒光纵横，血战八方！",
  ["$tshjitjjevs2"] = "七燿霜刃，力贯山河！",
}

-- local S = require "packages/szyihhsoohssaet/szyih_guos" 
--攻程不對
local canAdd=function(player)
  return 
           player:hasSkill(tshjitjjevs.name)
      and  player:getMark("_tshjitjjevs")==0 
      and  player:hasEmptyEquipSlot(Card.SubtypeWeapon) 
      and not table.find(player:getEquipments(Card.SubtypeWeapon), function(id)
        return Fk:getCardById(id).name == "tshjit_seec_kiams" end)
  end

  
local canRemove=function(player)
  return player:getMark("_tshjitjjevs")>0 and  player:hasEmptyEquipSlot(Card.SubtypeWeapon) ==false
  end
--武器欄增 武器欄失去牌 獲得技能 技能緟生效
local spec_add={
  on_trigger = function (self, event, target, player, data)
    local room=player.room
      player.room:setPlayerMark(player,"_tshjitjjevs",1)  --true
      -- local t=player:getTableMark("@[:]virtual_equip")
      -- table.insertIfNeed(t,"tshjit_seec_kiams")
      -- player.room:setPlayerMark(player,"@[:]virtual_equip",t)
      player.room:addTableMark(player,"@[:]virtual_equip","tshjit_seec_kiams")
      Fk:cloneCard("tshjit_seec_kiams"):onInstall(room, player)
  end,
}

local spec_remove={
  on_trigger = function (self, event, target, player, data)
    local room=player.room

    --  player:getMark(@_tshjitjjevs)>0 and not table.find(player:getEquipments(Card.SubtypeWeapon), function(id)
    --     return Fk:getCardById(id).name == "tshjit_seec_kiams") 

      player.room:setPlayerMark(player,"_tshjitjjevs",0)  --true
      player.room:removeTableMark(player,"@[:]virtual_equip","tshjit_seec_kiams")
      if not table.find(player:getEquipments(Card.SubtypeWeapon), function(id)
        return Fk:getCardById(id).name == "tshjit_seec_kiams" end) then --多个武器欄 --多來源
          Fk:cloneCard("tshjit_seec_kiams"):onUninstall(room, player)
      end
  end,
}
tshjitjjevs:addEffect(fk.AreaAborted, {  --puar
  priority=9,
  can_trigger = function(self, event, target, player, data)
    return target==player and canRemove(player)
  end,
  on_trigger=spec_remove.on_trigger,
})

tshjitjjevs:addEffect(fk.AreaResumed, {  
  priority=9,
  can_trigger = function(self, event, target, player, data)
    return target==player and canAdd(player)
  end,
  on_trigger=spec_add.on_trigger,
})

tshjitjjevs:addEffect(fk.AfterCardsMove, {
  priority=9,
  can_trigger = function(self, event, target, player, data)
    if not player:hasSkill(tshjitjjevs.name) then return end
    for _, move in ipairs(data) do
      if move.to==player and move.toArea == Card.PlayerEquip then--上裝僃   --應爲判斷是否置入某欄 
        return canRemove(player)
        -- return true
      end
    end
  end,
  on_trigger=spec_remove.on_trigger,
})

tshjitjjevs:addEffect(fk.AfterCardsMove, {
  priority=9,
  can_trigger = function(self, event, target, player, data)
    if not player:hasSkill(tshjitjjevs.name) then return end
    for _, move in ipairs(data) do
      if move.from == player then --下裝僃 --應爲判斷是否離開某欄 
        for _, info in ipairs(move.moveInfo) do
          if info.fromArea == Card.PlayerEquip then
            return  canAdd(player)
          end
        end
      end
    end
  end,
  on_trigger=spec_add.on_trigger,
})


tshjitjjevs: addAcquireEffect(function (self, player)
    if canAdd(player)
    then

      local room=player.room
      player.room:setPlayerMark(player,"_tshjitjjevs",1)  --true
      local t=player:getTableMark("@[:]virtual_equip")
      table.insertIfNeed(t,"tshjit_seec_kiams")
      player.room:setPlayerMark(player,"@[:]virtual_equip",t)
      -- room:handleAddLoseSkills(player,"#tshjit_seec_kiams_skill", tshjitjjevs.name, false, true)
      -- room:handleAddLoseSkills(player,"tshjit_seec_kiams_skill", tshjitjjevs.name, false, true)
      Fk:cloneCard("tshjit_seec_kiams"):onInstall(room, player)
    end
end)

tshjitjjevs:addLoseEffect(function (self, player)
   if player:getMark("_tshjitjjevs")>0 then
      local room=player.room
      player.room:removeTableMark(player,"@[:]virtual_equip","tshjit_seec_kiams")
      player.room:setPlayerMark(player,"_tshjitjjevs",0)  --true
      if not table.find(player:getEquipments(Card.SubtypeWeapon), function(id)  --多來源處理?
          return Fk:getCardById(id).name == "tshjit_seec_kiams" end) then
          Fk:cloneCard("tshjit_seec_kiams"):onUninstall(room, player)
      end
    end

end
)

