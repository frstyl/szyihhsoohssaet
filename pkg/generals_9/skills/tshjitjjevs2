tshjitjjevs: addAcquireEffect(function (self, player)
    if canAdd(player)
    then
    spec_add(player)
    end
end)

tshjitjjevs:addLoseEffect(function (self, player)
   if player:getMark("_tshjitjjevs")>0 then
    spec_remove(player)
   end
end
)

tshjitjjevs:addEffect(fk.DamageCaused, {
  can_trigger = function(self, event, target, player, data)
    return target == player and player:hasSkill(tshjitjjevs.name) 
    and (not data.chain) 
    and player.room.logic:damageByCardEffect()
    and
      data.card and data.card.trueName == "ssaet" and not data.to:isNude()
    and Fk.skills["#tshjit_seec_kiams_skill"] ~= nil and Fk.skills["#tshjit_seec_kiams_skill"]:isEffectable(player)
  end,
  on_trigger = function(self, event, target, player, data)
    if not player.room:askToSkillInvoke(player, {
      skill_name = "#tshjit_seec_kiams_skill",
    }) then return end

    local room = player.room
    -- room:broadcastPlaySound("./packages/standard_cards/audio/card/eight_diagram")
    -- room:setEmotion(player, "./packages/standard_cards/image/anim/eight_diagram")
    local skill = Fk.skills["#tshjit_seec_kiams_skill"]
    skill:use(event, target, player, data)
  end,
})

